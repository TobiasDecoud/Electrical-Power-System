	(gr_text_box "VIAS STITCHING\nf = 1Ghz (ruido maximo)\nc = 3×10⁸ m/s (velocidad de la luz)\nλ_pcb = c / (f × √εr)\nλ_pcb = 3×10⁸ / (1×10⁹ × √4.1)\nλ_pcb = 0.30 / √4.1\nλ_pcb = 0.30 / 2.025\nλ_pcb ≈ 14.8 cm\n\nλ/10 ≈ 1.48 cm ≈ 14.8 mm (maximo)\n\ndistancia entre vias = 10 mm"
		(start 37.975 64.9)
		(end 92 95.1)
		(margins 1.0025 1.0025 1.0025 1.0025)
